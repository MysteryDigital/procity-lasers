---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  category: string;
  slug: string;
  description: string;
  coverImage?: ImageMetadata;
  publishDate: Date;
  readingTime: number;
}

const { title, category, slug, description, coverImage, publishDate, readingTime } = Astro.props;

const categoryLabels: Record<string, string> = {
  graffiti:       'Graffiti',
  heritage:       'Heritage',
  'fire-damage':  'Fire Damage',
  industrial:     'Industrial',
  'paint-removal':'Paint Removal',
};

const label = categoryLabels[category] ?? category;
const dateStr = publishDate.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---

<a href={`/blog/${category}/${slug}/`} class="group block bg-surface">

  {/* ── Cover image (only when available) ── */}
  {coverImage && (
    <div class="relative aspect-[16/9] overflow-hidden">
      <Image
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        widths={[400, 800]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      />
      <span
        class="absolute bottom-2.5 left-3 text-[8.5px] font-semibold tracking-[0.14em] uppercase bg-neutral-dark/75 text-surface/75 px-2 py-[3px]"
        aria-hidden="true"
      >
        {label}
      </span>
    </div>
  )}

  {/* ── Card body ── */}
  <div class="px-5 pt-5 pb-5">
    <div class="text-[9px] font-semibold tracking-[0.14em] uppercase text-neutral-mid mb-2.5">{label}</div>
    <h2 class="text-[15px] font-medium text-neutral-dark group-hover:text-accent transition-colors leading-[1.4] tracking-[-0.01em] mb-2">
      {title}
    </h2>
    {description && (
      <p class="text-[13px] text-neutral-mid leading-[1.6] line-clamp-2 mb-3">{description}</p>
    )}
    <div class="flex items-center gap-2.5 text-[10px] tracking-[0.08em] uppercase text-neutral-mid">
      <span>{readingTime} min read</span>
      <span aria-hidden="true">·</span>
      <time datetime={publishDate.toISOString()}>{dateStr}</time>
    </div>
  </div>

</a>
