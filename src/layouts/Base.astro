---
import '../styles/tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  noindex?: boolean;
  ogImage?: string;
  preloadImage?: string;
  headerTransparent?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  noindex = false,
  ogImage,
  preloadImage,
  headerTransparent = false,
} = Astro.props;

const canonical = canonicalUrl ?? new URL(Astro.url.pathname, 'https://www.procitylasers.com').href;
const siteTitle = title === 'Pro City Laser Removal'
  ? title
  : `${title} | Pro City Laser Removal`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <link rel="canonical" href={canonical} />
    )}

    <link rel="sitemap" href="/sitemap-index.xml" />

    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} />
    )}

    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta name="twitter:card" content="summary_large_image" />
      </>
    )}
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pro City Laser Removal" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <slot name="head" />

    <!-- Suppress cookie banner before paint for returning visitors -->
    <script is:inline>
      if (localStorage.getItem('cookie_consent')) {
        document.documentElement.classList.add('cookie-consent-given');
      }
    </script>
  </head>
  <body class="bg-surface text-on-surface">
    <Header transparent={headerTransparent} />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
