---
import Base from '../../layouts/Base.astro';
import EnquiryForm from '../../components/EnquiryForm.astro';

const services = [
  {
    slug: 'graffiti',
    label: 'Graffiti Removal',
    headline: 'Commercial graffiti removal for councils and public realm',
    desc: 'High precision removal that significantly reduces ghosting compared to pressure washing or chemical stripping. The laser is safe on brick, stone, metal and render. A solution for, but not limited to, Local Authorities, Property Managers, Businesses and Private Clients.',
  },
  {
    slug: 'heritage',
    label: 'Heritage Conservation',
    headline: 'Non-abrasive laser cleaning for listed buildings and historic stonework',
    desc: 'Non-abrasive laser cleaning for listed buildings and historic stonework. No moisture, no residue, no abrasion - safe on carved detail polychrome surfaces and irreplaceable masonry.',
  },
  {
    slug: 'fire-damage',
    label: 'Fire Damage Remediation',
    headline: 'Fire damage remediation — working directly with loss adjusters and insurers',
    desc: 'Soot removal without secondary damage to the substrate. A precise non-invasive alternative to traditional cleaning methods. The laser cleaning method is suitable for but not limited to, Insurers, Loss Adjusters, Restoration Contractors and Property Owners.',
  },
  {
    slug: 'industrial',
    label: 'Industrial Cleaning',
    headline: 'Industrial laser cleaning and surface preparation',
    desc: 'Precision laser cleaning and surface preparation for industrial purposes to include structures, plant and equipment. Non-abrasive non-invasive and with a professional approach.',
  },
  {
    slug: 'paint-removal',
    label: 'Paint Removal',
    headline: 'Laser paint stripping — substrate-safe coating removal',
    desc: 'Precision removal of paint and coatings with full substrate preservation. Before/after evidence on every project.',
  },
  {
    slug: 'surface-preparation',
    label: 'Surface Preparation',
    headline: 'Precision surface profiling and pre-treatment',
    desc: 'Precision surface profiling and pre-treatment ahead of re-rendering or coating application - non-abrasive and suitable for stone brick metal and concrete.',
  },
];
---

<Base
  title="Services"
  description="Pro City Laser Removal and Restoration provides specialist laser cleaning across six service areas: graffiti removal, heritage conservation, fire damage remediation, industrial cleaning, paint removal and surface preparation. UK nationwide."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-neutral-mid mb-8">
      <ol class="flex gap-2">
        <li><a href="/" class="hover:text-neutral-dark transition-colors">Home</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-on-surface">Services</li>
      </ol>
    </nav>

    <header class="max-w-2xl mb-14">
      <h1 class="text-4xl font-semibold text-neutral-dark mb-4">Services</h1>
      <p class="text-lg text-neutral-mid">
        We provide specialist laser cleaning across six areas of work — each with its own
        buyer type, its own substrate considerations, and its own evidence requirements.
        Select a service to see process detail, project evidence, and relevant credentials.
      </p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s) => (
        <li>
          <a
            href={`/services/${s.slug}/`}
            class="group block h-full border border-neutral-mid/10 hover:border-accent p-8 transition-colors"
          >
            <p class="text-xs font-medium text-neutral-mid uppercase tracking-widest mb-3">{s.label}</p>
            <h2 class="text-xl font-semibold text-neutral-dark group-hover:text-accent transition-colors mb-3">
              {s.headline}
            </h2>
            <p class="text-sm text-neutral-mid leading-relaxed">{s.desc}</p>
            <p class="mt-5 text-sm font-medium text-accent">
              See {s.label.toLowerCase()} work →
            </p>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <EnquiryForm />
</Base>
