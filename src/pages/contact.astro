---
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
---

<Base
  title="Contact"
  description="Get in touch with Pro City Laser Removal — UK-wide specialist laser cleaning. Call, email, or use the enquiry form."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-neutral-mid mb-8">
      <ol class="flex gap-2">
        <li><a href="/" class="hover:text-neutral-dark transition-colors">Home</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-on-surface">Contact</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h1 class="text-4xl font-semibold text-neutral-dark mb-6">Get in touch</h1>
        <p class="text-neutral-mid mb-8">
          We respond to all enquiries within one working day. For urgent projects, call directly.
        </p>

        <dl class="space-y-4 text-sm">
          <div>
            <dt class="text-xs font-medium text-neutral-mid uppercase tracking-widest mb-1">Phone</dt>
            <dd>
              <a href="tel:+447878261529" class="text-on-surface hover:text-accent transition-colors">07878 261529</a>
              <br/>
              <a href="tel:+441733248117" class="text-on-surface hover:text-accent transition-colors">01733 248117</a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-neutral-mid uppercase tracking-widest mb-1">Email</dt>
            <dd>
              <a href="mailto:info@procitylasers.com" class="text-on-surface hover:text-accent transition-colors">
                info@procitylasers.com
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-neutral-mid uppercase tracking-widest mb-1">Coverage</dt>
            <dd class="text-on-surface">UK nationwide</dd>
          </div>
        </dl>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-neutral-dark mb-6">Send an enquiry</h2>
        <form
          name="enquiry"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="enquiry" />
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class="block text-sm font-medium text-on-surface mb-1">
              Name <span aria-label="required">*</span>
            </label>
            <input id="name" type="text" name="name" required aria-required="true" autocomplete="name"
              class="w-full border border-neutral-mid/40 bg-surface px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>

          <div>
            <label for="organisation" class="block text-sm font-medium text-on-surface mb-1">
              Company / Organisation
            </label>
            <input id="organisation" type="text" name="organisation" autocomplete="organization"
              class="w-full border border-neutral-mid/40 bg-surface px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-on-surface mb-1">
              Email <span aria-label="required">*</span>
            </label>
            <input id="email" type="email" name="email" required aria-required="true" autocomplete="email"
              class="w-full border border-neutral-mid/40 bg-surface px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-on-surface mb-1">
              Project description <span aria-label="required">*</span>
            </label>
            <textarea id="message" name="message" rows={5} required aria-required="true"
              class="w-full border border-neutral-mid/40 bg-surface px-3 py-2 text-sm focus:outline-none focus:border-accent resize-y"></textarea>
          </div>

          <button type="submit"
            class="w-full bg-accent text-surface py-3 text-sm font-medium hover:opacity-90 transition-opacity">
            Send enquiry
          </button>
        </form>
      </div>
    </div>
  </div>
</Base>
