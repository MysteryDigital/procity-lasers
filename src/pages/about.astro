---
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
---

<Base
  title="About"
  description="Pro City Laser Removal and Restoration is the specialist laser cleaning division of Pro City Painters Limited. UK-wide laser cleaning for graffiti, heritage, fire damage, industrial, paint removal and surface preparation."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav aria-label="Breadcrumb" class="text-sm text-neutral-mid mb-8">
      <ol class="flex gap-2">
        <li><a href="/" class="hover:text-neutral-dark transition-colors">Home</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-on-surface">About</li>
      </ol>
    </nav>

    <header class="mb-12">
      <h1 class="text-4xl font-semibold text-neutral-dark mb-4">About Pro City Laser Removal and Restoration</h1>
      <p class="text-lg text-neutral-mid">
        Specialist laser cleaning across the UK — graffiti, heritage, brickwork, fire damage, industrial, paint removal and surface preparation.
      </p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-neutral-dark mb-4">About us</h2>
      <div class="prose prose-neutral max-w-none text-on-surface">
        <p>
          Pro City Laser Removal and Restoration is the specialist laser cleaning division of Pro City Painters Limited, a decorating company with over 25 years of experience.
        </p>
        <p>
          Combining that established foundation with advanced non-abrasive laser cleaning technology, we provide precision surface restoration to include graffiti removal, heritage conservation, fire damage remediation, industrial cleaning, laser paint stripping and surface preparation working across the UK.
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-neutral-dark mb-4">Why laser cleaning</h2>
      <div class="prose prose-neutral max-w-none text-on-surface">
        <p>
          Laser Cleaning is non-abrasive, chemical free and precise enough for the most sensitive substrates including carved heritage stonework, polychrome surfaces and irreplaceable masonry. It leaves no secondary waste stream and produces a cleaner more controlled result than traditional sandblasting or chemical methods. Using 300W pulsed laser cleaning systems, the process carries less risk to the substrate, making it suited from everything from delicate heritage detail to everyday soot, graffiti and coating removal.
        </p>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-neutral-dark mb-4">The Managing Director</h2>
      <p class="text-neutral-mid">Spencer Hutson — photograph to be supplied.</p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-neutral-dark mb-4">Insurance &amp; compliance</h2>
      <p class="text-neutral-mid">
        Full public liability and employer's liability insurance is in place. RAMS and COSHH documentation are available on request.
      </p>
      <p class="mt-3">
        <a href="/contact/" class="text-accent hover:underline text-sm">
          Request certificates or documentation
        </a>
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-semibold text-neutral-dark mb-4">Sister company</h2>
      <p class="text-neutral-mid">
        Pro City Laser Removal is part of the same group as{' '}
        <a
          href="https://www.procitypainters.co.uk"
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Pro City Painters (opens in new tab)"
        >
          Pro City Painters
        </a>
        {' '}— a complementary service for clients who require both cleaning and redecoration under the same professional standards.
      </p>
    </section>
  </div>

  <EnquiryForm />
</Base>
