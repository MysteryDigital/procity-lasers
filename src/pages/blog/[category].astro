---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { readingTime } from '../../lib/readingTime';

export function getStaticPaths() {
  return [
    { params: { category: 'graffiti' } },
    { params: { category: 'heritage' } },
    { params: { category: 'fire-damage' } },
    { params: { category: 'industrial' } },
    { params: { category: 'paint-removal' } },
  ];
}

const { category } = Astro.params;

const categoryMeta: Record<string, { label: string; description: string; intro: string }> = {
  graffiti: {
    label: 'Graffiti',
    description: 'Guides and case studies on laser graffiti removal — for councils, facilities managers, and public realm teams.',
    intro: 'Technical articles and case studies on commercial laser graffiti removal. Covering council framework procurement, substrate-specific methods, and the difference between reactive and planned removal programmes.',
  },
  heritage: {
    label: 'Heritage Conservation',
    description: 'Technical articles on laser cleaning for listed buildings, historic stonework, and conservation projects.',
    intro: 'In-depth guidance on laser cleaning for listed buildings and historic structures. Written for conservation architects, heritage trusts, church property teams, and local authority conservation officers.',
  },
  'fire-damage': {
    label: 'Fire Damage',
    description: 'Articles on fire damage laser remediation — for loss adjusters, insurers, and contractors.',
    intro: 'Articles on fire and smoke damage remediation using laser cleaning. Covering soot and char removal, documentation for insurance claims, and working with loss adjusters on structural surfaces.',
  },
  industrial: {
    label: 'Industrial Cleaning',
    description: 'Technical guides on industrial laser surface preparation and cleaning for steel, concrete, and infrastructure.',
    intro: 'Technical guides on industrial laser cleaning and surface preparation. Covering steel structure maintenance, bridge and infrastructure works, cleanliness grades, and pre-coating preparation standards.',
  },
  'paint-removal': {
    label: 'Paint Removal',
    description: 'Articles on laser paint stripping — covering historic ironwork, lead paint, and multi-layer coatings.',
    intro: 'Articles on laser paint and coating removal from historic and industrial structures. Covering ornate ironwork, lead paint obligations, multi-layer systems, and substrate-safe preparation for redecoration.',
  },
};

const meta = categoryMeta[category] ?? {
  label: category,
  description: `Articles on ${category} laser cleaning.`,
  intro: '',
};

const posts = await getCollection('blog', ({ data }) => !data.draft && data.category === category);
posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

// All category slugs and labels for the filter tab row
const allCategories = [
  { slug: 'graffiti',       label: 'Graffiti' },
  { slug: 'heritage',       label: 'Heritage' },
  { slug: 'fire-damage',    label: 'Fire Damage' },
  { slug: 'industrial',     label: 'Industrial' },
  { slug: 'paint-removal',  label: 'Paint Removal' },
] as const;
---

<Base
  title={`${meta.label} Articles | Pro City Laser Removal`}
  description={meta.description}
>

  {/* ── PAGE HEADER ── */}
  <section class="bg-surface pt-16 pb-12">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">

      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-[11.5px] text-neutral-mid">
          <li><a href="/" class="hover:text-neutral-dark transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-neutral-mid/50">›</li>
          <li><a href="/blog/" class="hover:text-neutral-dark transition-colors">Blog</a></li>
          <li aria-hidden="true" class="text-neutral-mid/50">›</li>
          <li aria-current="page" class="text-neutral-dark">{meta.label}</li>
        </ol>
      </nav>

      {/* Eyebrow + h1 + intro */}
      <div class="flex items-center gap-3 mb-3.5">
        <div class="w-6 h-px bg-neutral-mid" aria-hidden="true"></div>
        <span class="text-[10px] font-medium tracking-[0.18em] text-neutral-mid uppercase">Laser Cleaning Resources</span>
      </div>
      <div class="max-w-2xl">
        <h1 class="text-[clamp(32px,4vw,44px)] font-light text-neutral-dark tracking-[-0.02em] leading-[1.1] mb-4">
          {meta.label}
        </h1>
        {meta.intro && (
          <p class="text-[16px] leading-[1.72] text-neutral-mid">{meta.intro}</p>
        )}
      </div>
    </div>
  </section>


  {/* ── CATEGORY FILTER TABS ── */}
  <section class="bg-surface border-b border-neutral-light">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">
      <nav aria-label="Filter articles by category">
        <ul class="flex flex-wrap gap-0 -mb-px" role="list">
          <li>
            <a
              href="/blog/"
              class="inline-block px-5 py-3.5 text-[11.5px] font-medium tracking-[0.06em] text-neutral-mid border-b-2 border-transparent hover:text-neutral-dark hover:border-neutral-mid transition-colors"
            >
              All
            </a>
          </li>
          {allCategories.map(({ slug, label: tabLabel }) => {
            const isActive = slug === category;
            return (
              <li>
                <a
                  href={`/blog/${slug}/`}
                  class={`inline-block px-5 py-3.5 text-[11.5px] font-medium tracking-[0.06em] border-b-2 transition-colors ${
                    isActive
                      ? 'border-accent text-accent'
                      : 'border-transparent text-neutral-mid hover:text-neutral-dark hover:border-neutral-mid'
                  }`}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {tabLabel}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </div>
  </section>


  {/* ── ARTICLE GRID ── */}
  <section class="bg-surface py-14">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-light border border-neutral-light">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              category={post.data.category}
              slug={post.slug}
              description={post.data.description}
              coverImage={post.data.coverImage}
              publishDate={post.data.publishDate}
              readingTime={readingTime(post.body)}
            />
          ))}
        </div>
      ) : (
        <p class="text-neutral-mid text-[15px]">{meta.label} articles will appear here once published.</p>
      )}
    </div>
  </section>

</Base>
