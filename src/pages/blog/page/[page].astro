---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import BlogCard from '../../../components/BlogCard.astro';
import BlogPagination from '../../../components/BlogPagination.astro';
import { readingTime } from '../../../lib/readingTime';

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  allPosts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

  const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);

  // Page 1 is handled by blog/index.astro; generate paths only for pages 2+
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
    const page = i + 2;
    const start = (page - 1) * PAGE_SIZE;
    return {
      params: { page: String(page) },
      props: {
        posts: allPosts.slice(start, start + PAGE_SIZE),
        currentPage: page,
        totalPages,
      },
    };
  });
}

interface Props {
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;

function pageUrl(n: number): string {
  return n === 1 ? '/blog/' : `/blog/page/${n}/`;
}

const prevUrl = pageUrl(currentPage - 1);
const nextUrl = currentPage < totalPages ? pageUrl(currentPage + 1) : null;

const categories = [
  { slug: 'graffiti',       label: 'Graffiti' },
  { slug: 'heritage',       label: 'Heritage' },
  { slug: 'fire-damage',    label: 'Fire Damage' },
  { slug: 'industrial',     label: 'Industrial' },
  { slug: 'paint-removal',  label: 'Paint Removal' },
];
---

<Base
  title={`Laser Cleaning Resources & Case Studies — Page ${currentPage}`}
  description="Articles on commercial laser cleaning — graffiti removal, heritage conservation, fire damage remediation. Written for councils, contractors, and heritage professionals."
  canonicalUrl={`https://www.procitylasers.com/blog/page/${currentPage}/`}
>
  <Fragment slot="head">
    <link rel="prev" href={`https://www.procitylasers.com${prevUrl}`} />
    {nextUrl && <link rel="next" href={`https://www.procitylasers.com${nextUrl}`} />}
  </Fragment>

  {/* ── PAGE HEADER ── */}
  <section class="bg-surface pt-16 pb-12">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">
      <div class="flex items-center gap-3 mb-3.5">
        <div class="w-6 h-px bg-neutral-mid" aria-hidden="true"></div>
        <span class="text-[10px] font-medium tracking-[0.18em] text-neutral-mid uppercase">Laser Cleaning Resources</span>
      </div>
      <div class="max-w-2xl">
        <h1 class="text-[clamp(32px,4vw,44px)] font-light text-neutral-dark tracking-[-0.02em] leading-[1.1] mb-4">
          Guides, case studies, and technical articles
        </h1>
        <p class="text-[16px] leading-[1.72] text-neutral-mid">
          In-depth articles on laser cleaning for councils, heritage bodies, insurers, and contractors. Covering graffiti removal, heritage stonework, fire damage remediation, industrial cleaning, and paint stripping.
        </p>
      </div>
    </div>
  </section>


  {/* ── CATEGORY FILTER ── */}
  <section class="bg-surface border-b border-neutral-light">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">
      <nav aria-label="Filter articles by category">
        <ul class="flex flex-wrap gap-0 -mb-px" role="list">
          <li>
            <a
              href="/blog/"
              class="inline-block px-5 py-3.5 text-[11.5px] font-medium tracking-[0.06em] border-b-2 border-accent text-accent"
            >
              All
            </a>
          </li>
          {categories.map((c) => (
            <li>
              <a
                href={`/blog/${c.slug}/`}
                class="inline-block px-5 py-3.5 text-[11.5px] font-medium tracking-[0.06em] text-neutral-mid border-b-2 border-transparent hover:text-neutral-dark hover:border-neutral-mid transition-colors"
              >
                {c.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </section>


  {/* ── ARTICLE GRID ── */}
  <section class="bg-surface py-14">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-light border border-neutral-light">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            category={post.data.category}
            slug={post.slug}
            description={post.data.description}
            coverImage={post.data.coverImage}
            publishDate={post.data.publishDate}
            readingTime={readingTime(post.body)}
          />
        ))}
      </div>
      <BlogPagination currentPage={currentPage} totalPages={totalPages} />
    </div>
  </section>

</Base>
