---
import Base from '../layouts/Base.astro';

const services = [
  { num: '01', slug: 'graffiti',           name: 'Graffiti Removal',         desc: 'Precision graffiti removal from stonework, brick, render, metal and public realm surfaces - heritage or modern. No abrasion, no chemicals, no residue, no substrate damage.' },
  { num: '02', slug: 'heritage',           name: 'Heritage Conservation',    desc: 'Non-invasive laser cleaning for Grade 1 and Grade 2 listed buildings using methods recognised by conservation professionals and aligned with heritage best practise.' },
  { num: '03', slug: 'fire-damage',        name: 'Fire Damage Remediation',  desc: 'Removal from stone, brick, timber, metal and masonry surfaces - working directly with Loss Adjusters, Insurers and Restoration Contractors.' },
  { num: '04', slug: 'industrial',         name: 'Industrial Cleaning',      desc: 'Surface preparation and precision cleaning for steel, concrete, machinery and industrial structures - at scale, with no abrasive media or secondary waste.' },
  { num: '05', slug: 'paint-removal',      name: 'Paint Removal',            desc: 'Complete coating removal from stone, brick, metal, timber and render – paint, varnish and specialist finishes - with full substrate preservation.' },
  { num: '06', slug: 'surface-preparation', name: 'Surface Preparation',     desc: 'Precision surface profiling and pre-treatment for re-rendering, coating application and structural repair - on stone, brick, metal and concrete with no substrate damage.' },
];

const steps = [
  { num: '01', title: 'Site Assessment',        desc: 'Condition survey with material identification, contamination mapping, and full photographic documentation before any work is proposed.' },
  { num: '02', title: 'Method Specification',   desc: 'Calibrated laser parameters selected for each substrate. Written method statement and risk assessment issued for client approval.' },
  { num: '03', title: 'Treatment & Sign-off',   desc: 'Precision treatment with continuous monitoring. Full photographic record issued on completion for planning and insurance purposes.' },
];

const stats = [
  { value: '15+',    label: 'Years of specialist practice' },
  { value: 'I & II*', label: 'Listed buildings treated' },
  { value: '100%',   label: 'Documentation rate' },
  { value: '0',      label: 'Substrate damage incidents' },
];

const placeholderProjects = [
  { category: 'Heritage Conservation', title: 'Peterborough Cathedral',               desc: 'Graffiti removal from historic stonework — before and after images to follow' },
  { category: 'Fire Damage',           title: 'Commercial Premises, Manchester',      desc: 'Brick — soot and char remediation' },
  { category: 'Industrial',            title: 'UK Holiday Village Metalwork',         desc: 'Rust removal, prep and paint on outdoor metalwork' },
];
---

<Base
  title="Pro City Laser Removal and Restoration"
  description="UK-wide specialist laser cleaning — graffiti, heritage, fire damage, industrial, paint removal and surface preparation. Photo evidence on every project."
  headerTransparent={true}
>

  {/* ── HERO ── */}
  <section class="lg:min-h-screen bg-accent relative overflow-hidden flex items-start lg:items-center pt-28">
    <div class="bg-grid-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-0 right-0 h-44 bg-gradient-to-b from-transparent to-accent/40 pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12 py-12 lg:py-20 w-full grid grid-cols-1 lg:grid-cols-[55%_1fr] lg:gap-[72px] items-center">

      {/* Text column */}
      <div class="hero-fade-up">
        <div class="flex items-center gap-3 mb-9">
          <div class="w-7 h-px bg-surface/30" aria-hidden="true"></div>
          <span class="text-[10px] font-medium tracking-[0.2em] text-surface/65 uppercase">UK Laser Cleaning Specialists</span>
        </div>
        <h1 class="m-0 mb-7 text-[clamp(46px,5vw,68px)] font-light leading-[1.07] text-surface tracking-[-0.025em]">
          Precision you can<br>trust with things<br>that matter.
        </h1>
        <p class="m-0 mb-11 text-[17px] leading-[1.72] text-surface/65 max-w-[520px]">
          Specialist laser cleaning for stonework, brickwork, metal, timber and other surfaces, from listed buildings and heritage sites to fire and soot damaged homes and industrial structures. Non-abrasive, fully documented and compliant.
        </p>
        <div class="flex items-center gap-3.5 flex-wrap">
          <a href="/work/" class="inline-flex items-center h-12 px-8 bg-surface text-accent text-[14px] font-medium tracking-[0.025em] hover:bg-surface/90 transition-colors">
            See our work
          </a>
          <a href="/contact/" class="inline-flex items-center h-12 px-8 border border-surface/30 text-surface text-[14px] font-medium tracking-[0.025em] hover:border-surface/60 transition-colors">
            Discuss a project
          </a>
        </div>
      </div>

      {/* Visual column — before/after placeholder */}
      <div class="hero-fade-up-2 hidden lg:block" aria-hidden="true">
        <div class="relative aspect-[4/3] border border-surface/16 overflow-hidden bg-surface-dark">
          <div class="bg-grid-overlay-subtle absolute inset-0"></div>
          <div class="absolute left-0 top-0 w-1/2 h-full bg-on-surface/20"></div>
          <div class="absolute left-1/2 top-0 bottom-0 w-px bg-surface/32 -translate-x-1/2"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-accent/90 border border-surface/22 flex items-center justify-center">
            <svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M1 5h16M13 1l4 4-4 4M5 1L1 5l4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-surface/55"/></svg>
          </div>
          <div class="absolute top-0 left-0 right-0 px-4 py-[11px] flex justify-between border-b border-surface/7 bg-surface-dark/65">
            <span class="text-[9px] tracking-[0.14em] uppercase text-surface/40">Project Photography</span>
            <span class="text-[9px] tracking-[0.1em] text-surface/25">Heritage Conservation</span>
          </div>
          <div class="absolute bottom-[13px] left-[14px] text-[8.5px] tracking-[0.14em] uppercase text-surface/35">Before</div>
          <div class="absolute bottom-[13px] right-[14px] text-[8.5px] tracking-[0.14em] uppercase text-surface/50">After</div>
        </div>
        <div class="grid grid-cols-2 gap-1.5 mt-1.5">
          <div class="aspect-video bg-surface-dark border border-surface/9 relative overflow-hidden">
            <div class="bg-grid-overlay-subtle absolute inset-0"></div>
            <div class="absolute bottom-2 left-2.5 text-[8px] tracking-[0.1em] text-surface/30 uppercase">Graffiti Removal</div>
          </div>
          <div class="aspect-video bg-surface-dark border border-surface/9 relative overflow-hidden">
            <div class="bg-grid-overlay-subtle absolute inset-0"></div>
            <div class="absolute bottom-2 left-2.5 text-[8px] tracking-[0.1em] text-surface/30 uppercase">Industrial</div>
          </div>
        </div>
        <p class="mt-2.5 text-[11px] text-surface/40 leading-[1.5]">Project photography added on completion of each contract</p>
      </div>
    </div>

    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 pointer-events-none" aria-hidden="true">
      <div class="w-px h-12 bg-gradient-to-b from-surface/22 to-transparent"></div>
    </div>
  </section>


  {/* ── TRUST BAR ── */}
  <section aria-label="Accreditations and compliance">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-px bg-neutral-light border-b border-neutral-light">
        {[
          { label: 'Compliance',     value: 'Cleaning and safety practises aligned with recognised UK standards' },
          { label: 'Accreditation',  value: 'CSCS Registered Operatives' },
          { label: 'Documentation',  value: 'Full Photo Record, Every Project' },
          { label: 'Insurance',      value: '£5M Public Liability Cover' },
        ].map((item) => (
          <div class="bg-surface px-6 py-[22px]">
            <div class="text-[9px] font-semibold tracking-[0.14em] uppercase text-neutral-mid mb-1.5">{item.label}</div>
            <div class="text-[13.5px] font-medium text-neutral-dark tracking-[0.01em]">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>


  {/* ── SERVICES ── */}
  <section id="services" class="bg-surface py-24">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12">
      <div class="flex items-center gap-3 mb-3.5">
        <div class="w-6 h-px bg-neutral-mid" aria-hidden="true"></div>
        <span class="text-[10px] font-medium tracking-[0.18em] text-neutral-mid uppercase">Services</span>
      </div>
      <div class="flex items-end justify-between mb-14 flex-wrap gap-4">
        <h2 class="m-0 text-[clamp(32px,4vw,44px)] font-light text-neutral-dark tracking-[-0.02em] leading-[1.1]">Specialist capabilities</h2>
        <a href="/contact/" class="flex items-center gap-1.5 text-[13px] font-medium text-accent tracking-[0.01em] hover:opacity-80 transition-opacity">
          <span>Discuss a project</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-light border border-neutral-light">
        {services.map((s) => (
          <a
            href={s.slug ? `/services/${s.slug}/` : '/contact/'}
            class="bg-surface px-7 pt-7 pb-6 flex flex-col hover:bg-neutral-light/40 transition-colors group"
          >
            <div class="text-[10px] font-medium tracking-[0.1em] text-neutral-light mb-4 tabular-nums" aria-hidden="true">{s.num}</div>
            <h3 class="m-0 mb-2.5 text-[15.5px] font-medium text-neutral-dark tracking-[-0.01em] leading-[1.3]">{s.name}</h3>
            <p class="m-0 mb-5 text-[13.5px] leading-[1.65] text-neutral-mid flex-1 text-justify">{s.desc}</p>
            <div class="flex items-center gap-1.5 text-[12px] font-medium text-accent tracking-[0.03em]" aria-hidden="true">
              <span>Learn more</span>
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  {/* ── PROCESS ── */}
  <section class="bg-accent py-24 relative overflow-hidden">
    <div class="bg-grid-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12 relative">
      <div class="flex items-center gap-3 mb-3.5">
        <div class="w-6 h-px bg-surface/30" aria-hidden="true"></div>
        <span class="text-[10px] font-medium tracking-[0.18em] text-surface/65 uppercase">How we work</span>
      </div>
      <div class="mb-16">
        <h2 class="m-0 text-[clamp(32px,4vw,44px)] font-light text-surface tracking-[-0.02em] leading-[1.15]">
          A rigorous, documented<br>process — every time.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-surface/8 border-t border-surface/12">
        {steps.map((step) => (
          <div class="bg-accent pt-10 pb-10 px-4 sm:px-8 md:pl-0 md:pr-11">
            <div class="text-[10px] font-normal tracking-[0.08em] text-surface/40 mb-5" aria-hidden="true">{step.num}</div>
            <h3 class="m-0 mb-3 text-[18px] font-medium text-surface tracking-[-0.01em]">{step.title}</h3>
            <p class="m-0 text-[14px] leading-[1.72] text-surface/65">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  {/* ── PROJECTS ── */}
  <section id="projects" class="bg-surface py-24">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12">
      <div class="flex items-center gap-3 mb-3.5">
        <div class="w-6 h-px bg-neutral-mid" aria-hidden="true"></div>
        <span class="text-[10px] font-medium tracking-[0.18em] text-neutral-mid uppercase">Projects</span>
      </div>
      <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
        <h2 class="m-0 text-[clamp(32px,4vw,44px)] font-light text-neutral-dark tracking-[-0.02em] leading-[1.1]">Selected work</h2>
        <a href="/work/" class="flex items-center gap-1.5 text-[13px] font-medium text-accent hover:opacity-80 transition-opacity">
          <span>View all projects</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-light border border-neutral-light">
        {placeholderProjects.map((p) => (
          <div class="bg-surface group">
            {/* Before/after placeholder — will be replaced with real BeforeAfterSlider */}
            <div class="aspect-[4/3] relative overflow-hidden bg-neutral-light" aria-hidden="true">
              <div class="absolute left-0 top-0 w-1/2 h-full bg-neutral-mid/20"></div>
              <div class="absolute left-1/2 top-0 bottom-0 w-px bg-neutral-dark/14 -translate-x-1/2"></div>
              <div class="absolute bottom-3 left-3 text-[8.5px] tracking-[0.12em] uppercase text-neutral-mid">Before</div>
              <div class="absolute bottom-3 right-3 text-[8.5px] tracking-[0.12em] uppercase text-neutral-mid">After</div>
            </div>
            <div class="px-5 py-4 pb-5">
              <div class="text-[9px] font-semibold tracking-[0.14em] uppercase text-neutral-mid mb-1.5">{p.category}</div>
              <div class="text-[15px] font-medium text-neutral-dark mb-1 tracking-[-0.01em]">{p.title}</div>
              <div class="text-[12.5px] text-neutral-mid leading-[1.5]">{p.desc}</div>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-4 text-[11.5px] text-neutral-mid leading-[1.55]">
        Photography added as projects complete. All images taken pre- and post-treatment with consistent framing for accurate comparison.
      </p>
    </div>
  </section>


  {/* ── CONTACT ── */}
  <section id="contact" class="bg-accent py-24 relative overflow-hidden">
    <div class="bg-grid-overlay absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="max-w-screen-xl mx-auto px-4 sm:px-8 lg:px-12 relative">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-[96px] items-start">

        {/* Contact details */}
        <div>
          <div class="flex items-center gap-3 mb-3.5">
            <div class="w-6 h-px bg-surface/30" aria-hidden="true"></div>
            <span class="text-[10px] font-medium tracking-[0.18em] text-surface/65 uppercase">Get in touch</span>
          </div>
          <h2 class="m-0 mb-5 text-[clamp(32px,4vw,44px)] font-light text-surface tracking-[-0.02em] leading-[1.1]">
            Discuss your<br>project.
          </h2>
          <p class="m-0 mb-11 text-[16px] leading-[1.72] text-surface/65">
            We respond to all enquiries within one working day. For urgent requirements, call direct.
          </p>
          <div class="border-t border-surface/10">
            <div class="flex justify-between items-center py-4 border-b border-surface/7">
              <span class="text-[10px] tracking-[0.12em] uppercase text-surface/55">Telephone</span>
              <a href="tel:+447878261529" class="text-[15px] font-medium text-surface hover:text-surface/80 transition-colors">07878 261529</a>
            </div>
            <div class="flex justify-between items-center py-4 border-b border-surface/7">
              <span class="text-[10px] tracking-[0.12em] uppercase text-surface/55">Email</span>
              <a href="mailto:info@procitylasers.com" class="text-[15px] font-medium text-surface hover:text-surface/80 transition-colors">info@procitylasers.com</a>
            </div>
            <div class="flex justify-between items-center py-4">
              <span class="text-[10px] tracking-[0.12em] uppercase text-surface/55">Coverage</span>
              <span class="text-[15px] font-medium text-surface">UK-Wide</span>
            </div>
          </div>
          <div class="mt-7 px-5 py-4 border border-surface/10 bg-surface/4">
            <p class="m-0 text-[13px] leading-[1.65] text-surface/60">
              All projects are preceded by a no-obligation site assessment. Written method statements and risk assessments provided before any work commences.
            </p>
          </div>
        </div>

        {/* Enquiry form */}
        <div>
          <form
            name="enquiry"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            class="flex flex-col gap-4"
          >
            <input type="hidden" name="form-name" value="enquiry" />
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out if you're human: <input name="bot-field" /></label>
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label for="name" class="block text-[9.5px] font-semibold tracking-[0.12em] uppercase text-surface/65 mb-2">
                  Name <span aria-label="required">*</span>
                </label>
                <input
                  id="name"
                  type="text"
                  name="name"
                  required
                  aria-required="true"
                  autocomplete="name"
                  class="block w-full h-[46px] px-3.5 bg-surface/6 border border-surface/14 text-surface text-[14px] outline-none focus:border-surface/50 transition-colors placeholder:text-surface/30"
                />
              </div>
              <div>
                <label for="organisation" class="block text-[9.5px] font-semibold tracking-[0.12em] uppercase text-surface/65 mb-2">
                  Organisation <span aria-label="required">*</span>
                </label>
                <input
                  id="organisation"
                  type="text"
                  name="organisation"
                  required
                  aria-required="true"
                  autocomplete="organization"
                  class="block w-full h-[46px] px-3.5 bg-surface/6 border border-surface/14 text-surface text-[14px] outline-none focus:border-surface/50 transition-colors placeholder:text-surface/30"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-[9.5px] font-semibold tracking-[0.12em] uppercase text-surface/65 mb-2">
                Email <span aria-label="required">*</span>
              </label>
              <input
                id="email"
                type="email"
                name="email"
                required
                aria-required="true"
                autocomplete="email"
                class="block w-full h-[46px] px-3.5 bg-surface/6 border border-surface/14 text-surface text-[14px] outline-none focus:border-surface/50 transition-colors placeholder:text-surface/30"
              />
            </div>

            <div>
              <label for="service" class="block text-[9.5px] font-semibold tracking-[0.12em] uppercase text-surface/65 mb-2">
                Service type
              </label>
              <div class="relative">
                <select
                  id="service"
                  name="service"
                  class="block w-full h-[46px] px-3.5 bg-surface/6 border border-surface/14 text-surface/80 text-[14px] outline-none appearance-none cursor-pointer focus:border-surface/50 transition-colors"
                >
                  <option value="" class="bg-accent text-surface">Select service type</option>
                  <option class="bg-accent text-surface">Graffiti Removal</option>
                  <option class="bg-accent text-surface">Heritage Conservation</option>
                  <option class="bg-accent text-surface">Fire Damage Remediation</option>
                  <option class="bg-accent text-surface">Industrial Cleaning</option>
                  <option class="bg-accent text-surface">Paint Removal</option>
                  <option class="bg-accent text-surface">Surface Preparation</option>
                </select>
                <svg class="absolute right-3.5 top-1/2 -translate-y-1/2 pointer-events-none text-surface/50" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                  <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>

            <div>
              <label for="message" class="block text-[9.5px] font-semibold tracking-[0.12em] uppercase text-surface/65 mb-2">
                Project description <span aria-label="required">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows={5}
                required
                aria-required="true"
                class="block w-full px-3.5 py-3 bg-surface/6 border border-surface/14 text-surface text-[14px] outline-none focus:border-surface/50 transition-colors resize-y leading-[1.6] placeholder:text-surface/30"
              ></textarea>
            </div>

            <button
              type="submit"
              class="h-[50px] w-full bg-surface text-accent text-[14px] font-medium tracking-[0.04em] border-none cursor-pointer hover:bg-surface/90 transition-colors"
            >
              Send enquiry
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Base>
